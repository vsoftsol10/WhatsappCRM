generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role   Role       @default(USER)
  status UserStatus @default(ACTIVE)

  phone        String?
  department   String?
  designation  String?
  address      String?
  profileImage String?

  isFirstLogin Boolean @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?

  customers Customer[]

  campaigns Campaign[]

  templates Template[]

  notifications Notification[]

  createdTasks Task[] @relation("CreatedTasks")

  assignedTasks Task[] @relation("AssignedTasks")

  createdTickets Ticket[] @relation("CreatedTickets")

  assignedTickets Ticket[] @relation("AssignedTickets")

  createdDeals Deal[] @relation("CreatedDeals")

  assignedDeals Deal[] @relation("AssignedDeals")

  dealActivities DealActivity[] @relation("CreatedDealActivities")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id      String  @id @default(uuid())
  name    String
  phone   String  @unique
  email   String?
  company String?
  source       String?
  requirements String?
  status  String  @default("ACTIVE")

  userId String
  user   User   @relation(fields: [userId], references: [id])

  conversations Conversation[]

  campaignRecipients CampaignRecipient[]

  templateRecipients TemplateRecipient[]

  tickets Ticket[]

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id String @id @default(uuid())

  phone String? @unique

  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  status      String  @default("OPEN")
  channel     String  @default("WHATSAPP")
  lastMessage String?
  unreadCount Int     @default(0)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  content     String
  imageUrl String?
  sender      String // CUSTOMER or AGENT
  messageType String @default("TEXT")
  status      String @default("SENT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id    Int     @id @default(autoincrement())
  name  String
  phone String?
  email String?

  company String?

  status LeadStatus
  source String?

  requirements String?

  assignedToId Int?

  isConverted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
}

enum CampaignType {
  PROMOTIONAL
  BROADCAST
  FOLLOW_UP
  ANNOUNCEMENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateCategory {
  MARKETING
  SUPPORT
  SALES
  UTILITY
  AUTHENTICATION
}

enum TemplatePurpose {
  WELCOME
  CUSTOM
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum DealStage {
  LEAD
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum NotificationType {
  LEAD
  TASK
  TICKET
  CUSTOMER
  DEAL
  CAMPAIGN
  SYSTEM
}

model Campaign {
  id String @id @default(uuid())

  name String

  type CampaignType

  messageContent String

  imageUrl String?

  status CampaignStatus @default(DRAFT)

  scheduledAt DateTime?

  audienceCount Int @default(0)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  recipients CampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignRecipient {
  id String @id @default(uuid())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status RecipientStatus @default(PENDING)

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@unique([campaignId, customerId])
}

model TemplateRecipient {
  id String @id @default(uuid())

  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status RecipientStatus @default(PENDING)

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  metaMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, customerId])

  @@index([templateId])
  @@index([customerId])
}

model Template {
  id String @id @default(uuid())

  name String

  category TemplateCategory

  messageType MessageType @default(TEXT)

  content String

  status TemplateStatus @default(DRAFT)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  recipients TemplateRecipient[]

  purpose TemplatePurpose @default(CUSTOM)

  autoSend Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id String @id @default(uuid())

  title       String
  description String?

  status TaskStatus @default(TODO)

  priority TaskPriority @default(MEDIUM)

  dueDate DateTime?

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdById])
}

model Ticket {
  id String @id @default(uuid())

  title       String
  description String?

  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([createdById])
  @@index([assignedToId])
}

model Deal {
  id String @id @default(uuid())

  title       String
  description String?

  value Float @default(0)

  stage DealStage @default(LEAD)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedDeals", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedDeals", fields: [assignedToId], references: [id])

  activities DealActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([customerId])
  @@index([createdById])
  @@index([assignedToId])
}

model DealActivity {
  id String @id @default(uuid())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  type String

  note String

  createdById String
  createdBy User @relation("CreatedDealActivities", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())

  title     String
  message   String

  type      NotificationType

  isRead    Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}