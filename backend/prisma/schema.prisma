generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String
  role             Role           @default(USER)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isFirstLogin     Boolean        @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  address          String?
  department       String?
  designation      String?
  phone            String?
  profileImage     String?
  status           UserStatus     @default(ACTIVE)
  campaigns        Campaign[]
  customers        Customer[]
  assignedDeals    Deal[]         @relation("AssignedDeals")
  createdDeals     Deal[]         @relation("CreatedDeals")
  dealActivities   DealActivity[] @relation("CreatedDealActivities")
  notifications    Notification[]
  assignedTasks    Task[]         @relation("AssignedTasks")
  createdTasks     Task[]         @relation("CreatedTasks")
  templates        Template[]
  assignedTickets  Ticket[]       @relation("AssignedTickets")
  createdTickets   Ticket[]       @relation("CreatedTickets")
}

model Customer {
  id                 String              @id @default(uuid())
  name               String
  phone              String              @unique
  email              String?
  company            String?
  status             String              @default("ACTIVE")
  userId             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  requirements       String?
  source             String?
  campaignRecipients CampaignRecipient[]
  conversations      Conversation?
  user               User                @relation(fields: [userId], references: [id])
  deals              Deal[]
  templateRecipients TemplateRecipient[]
  tickets            Ticket[]
}

model Conversation {
  id          String    @id @default(uuid())
  customerId  String?   @unique
  status      String    @default("OPEN")
  channel     String    @default("WHATSAPP")
  lastMessage String?
  unreadCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  phone       String?   @unique
  customer    Customer? @relation(fields: [customerId], references: [id])
  messages    Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  content        String
  sender         String
  messageType    String       @default("TEXT")
  status         String       @default("SENT")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  imageUrl       String?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Lead {
  id           Int        @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  status       LeadStatus
  source       String?
  requirements String?
  assignedToId Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isConverted  Boolean    @default(false)
  company      String?
}

model Campaign {
  id             String              @id @default(uuid())
  name           String
  type           CampaignType
  messageContent String
  status         CampaignStatus      @default(DRAFT)
  scheduledAt    DateTime?
  audienceCount  Int                 @default(0)
  createdById    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  imageUrl       String?
  createdBy      User                @relation(fields: [createdById], references: [id])
  recipients     CampaignRecipient[]
}

model CampaignRecipient {
  id          String          @id @default(uuid())
  campaignId  String
  customerId  String
  status      RecipientStatus @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime        @default(now())
  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
}

model TemplateRecipient {
  id            String          @id @default(uuid())
  templateId    String
  customerId    String
  status        RecipientStatus @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  metaMessageId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template      Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, customerId])
  @@index([templateId])
  @@index([customerId])
}

model Template {
  id          String              @id @default(uuid())
  name        String
  category    TemplateCategory
  messageType MessageType         @default(TEXT)
  content     String
  status      TemplateStatus      @default(DRAFT)
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  autoSend    Boolean             @default(false)
  purpose     TemplatePurpose     @default(CUSTOM)
  createdBy   User                @relation(fields: [createdById], references: [id])
  recipients  TemplateRecipient[]
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  createdById  String
  assignedToId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedTo   User         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy    User         @relation("CreatedTasks", fields: [createdById], references: [id])

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdById])
}

model Ticket {
  id           String         @id @default(uuid())
  title        String
  description  String?
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  customerId   String
  createdById  String
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignedTo   User?          @relation("AssignedTickets", fields: [assignedToId], references: [id])
  createdBy    User           @relation("CreatedTickets", fields: [createdById], references: [id])
  customer     Customer       @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([createdById])
  @@index([assignedToId])
}

model Deal {
  id           String         @id @default(uuid())
  title        String
  description  String?
  value        Float          @default(0)
  stage        DealStage      @default(LEAD)
  customerId   String
  createdById  String
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignedTo   User?          @relation("AssignedDeals", fields: [assignedToId], references: [id])
  createdBy    User           @relation("CreatedDeals", fields: [createdById], references: [id])
  customer     Customer       @relation(fields: [customerId], references: [id])
  activities   DealActivity[]

  @@index([stage])
  @@index([customerId])
  @@index([createdById])
  @@index([assignedToId])
}

model DealActivity {
  id          String   @id @default(uuid())
  dealId      String
  type        String
  note        String
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("CreatedDealActivities", fields: [createdById], references: [id])
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int              @id @default(autoincrement())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
}

enum CampaignType {
  PROMOTIONAL
  BROADCAST
  FOLLOW_UP
  ANNOUNCEMENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateCategory {
  MARKETING
  SUPPORT
  SALES
  UTILITY
  AUTHENTICATION
}

enum TemplatePurpose {
  WELCOME
  CUSTOM
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum DealStage {
  LEAD
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum NotificationType {
  LEAD
  TASK
  TICKET
  CUSTOMER
  DEAL
  CAMPAIGN
  SYSTEM
}
